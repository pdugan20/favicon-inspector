{
  "name": "favicon-inspector",
  "version": "0.1.0",
  "type": "module",
  "description": "Inspect what Google's favicon services serve/cache for a set of domains.",
  "keywords": [
    "favicon",
    "google",
    "cli",
    "icon",
    "cache"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pdugan20/favicon-inspector.git"
  },
  "bin": {
    "favicon-inspector": "dist/index.js"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "tsx src/index.ts",
    "favicons:generate": "tsx scripts/generate-favicons.ts",
    "favicons:preview": "tsx scripts/preview-favicons.ts",
    "build": "tsc -p tsconfig.build.json",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "lint:md": "markdownlint-cli2 '**/*.md' '#node_modules' '#reports'",
    "lint:deps": "knip",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepare": "husky",
    "prepublishOnly": "npm run build"
  },
  "lint-staged": {
    "*.{js,ts}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.md": [
      "markdownlint-cli2 --fix",
      "prettier --write"
    ],
    "*.{json,yml,yaml}": [
      "prettier --write"
    ]
  },
  "license": "MIT",
  "dependencies": {
    "fast-png": "^8.0.0",
    "jpeg-js": "^0.4.4"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^22.0.0",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^10.1.8",
    "favicons": "^7.3.0",
    "husky": "^9.1.7",
    "jiti": "^2.4.2",
    "knip": "^5.86.0",
    "lint-staged": "^16.3.3",
    "markdownlint-cli2": "^0.22.1",
    "prettier": "^3.8.1",
    "sharp": "^0.35.2",
    "tsx": "^4.23.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.62.0",
    "vitest": "~3.2.0"
  }
}
